{
  "name": "solopilot",
  "version": "1.68.0",
  "description": "Solopilot — le systeme d'exploitation autonome de l'entreprise d'une personne : veille, acquisition, CRM, facturation, comptabilite et agenda orchestres par des workflows pilotes par IA",
  "type": "module",
  "main": "dist/scheduler.js",
  "bin": {
    "solopilot": "dist/cli.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "cli": "node dist/cli.js",
    "dev:cli": "node --env-file=.env dist/cli.js",
    "build": "tsc && npm run build:frontend",
    "build:backend": "tsc",
    "build:frontend": "cd frontend && npx vite build",
    "start": "node dist/scheduler.js",
    "start:once": "node dist/index.js",
    "dev": "node --env-file=.env dist/scheduler.js",
    "dev:once": "node --env-file=.env dist/index.js",
    "workflow": "node dist/workflow/cli.js",
    "dev:workflow": "node --env-file=.env dist/workflow/cli.js",
    "dev:frontend": "cd frontend && npx vite",
    "generate:pwa-icons": "node scripts/generate-pwa-icons.mjs",
    "lint": "eslint src/",
    "test:workflow": "npm run build:backend && node scripts/workflow-smoke.mjs",
    "format": "prettier --write src/",
    "docker:build": "docker build --build-arg VERSION=$(node -p \"require('./package.json').version\") --build-arg BUILD_DATE=$(date -u +%Y-%m-%dT%H:%M:%SZ) -t ghcr.io/wifsimster/solopilot:latest .",
    "docker:tag": "VERSION=$(node -p \"require('./package.json').version\") && docker tag ghcr.io/wifsimster/solopilot:latest ghcr.io/wifsimster/solopilot:v$VERSION && docker tag ghcr.io/wifsimster/solopilot:latest ghcr.io/wifsimster/solopilot:$(echo $VERSION | cut -d. -f1-2) && docker tag ghcr.io/wifsimster/solopilot:latest ghcr.io/wifsimster/solopilot:$(echo $VERSION | cut -d. -f1)",
    "docker:push": "docker push ghcr.io/wifsimster/solopilot --all-tags",
    "release": "npm run build && npm run docker:build && npm run docker:tag && npm run docker:push",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@hono/node-server": "^1.19.11",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@schedule-x/calendar": "^4.6.0",
    "@schedule-x/events-service": "^4.6.0",
    "@schedule-x/react": "^4.1.0",
    "@schedule-x/theme-default": "^4.6.0",
    "@stripe/react-stripe-js": "^6.6.0",
    "@stripe/stripe-js": "^9.7.0",
    "@tanstack/react-table": "^8.21.3",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.8",
    "lucide-react": "^0.468.0",
    "node-cron": "^3.0.3",
    "openai": "^6.29.0",
    "playwright-core": "^1.60.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.1.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.39.0",
    "prettier": "^3.8.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.54.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.3.0"
  }
}
