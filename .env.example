# X username to scrape
X_USERNAME=wifsimster

# Session tokens for web scraping — extract from browser cookies after login
# 1. Log in to x.com in your browser
# 2. Open DevTools → Application → Cookies → https://x.com
# 3. Copy the values of "auth_token" and "ct0"
X_SESSION_AUTH_TOKEN=
X_SESSION_CSRF_TOKEN=

# Optional: override GraphQL operation IDs when X changes them
# X_GQL_USER_BY_SCREEN_NAME_ID=qW5u-DAuXpMEG0zA1F7UGQ
# X_GQL_HOME_TIMELINE_ID=ulQKqowrFU94KfUAZqgGvg

# GitHub Personal Access Token (with models:read scope) — https://github.com/settings/tokens
GITHUB_TOKEN=

# Optional — model from GitHub Models catalog (https://github.com/marketplace/models)
# AI_MODEL=openai/gpt-4.1
# TWEETS_LOOKBACK_DAYS=1
# DRY_RUN=true
# CRON_SCHEDULE=30 7 * * *

# Back-office
# ADMIN_PASSWORD=your-secure-password
# WEB_PORT=3000

# Optional — Discord webhook URL for automatic summary notifications
# Create a webhook in Discord: Server Settings → Integrations → Webhooks
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Optional — Stripe secret key for the Facturation module. When unset, invoicing
# works as a local ledger and Stripe sync is a no-op. https://dashboard.stripe.com/apikeys
# STRIPE_API_KEY=sk_live_...

# Optional — calendar ICS feed URL for the Agenda module (e.g. Google Calendar
# "secret address in iCal format"). When unset, Agenda works as a local store.
# AGENDA_ICS_URL=https://calendar.google.com/calendar/ical/.../basic.ics

# Optional — custom SQLite database path (defaults to ./data/bot.db)
# DB_PATH=./data/bot.db

# Optional — route production veille through the workflow engine (the "flip",
# ADR-0020). Behaviour is identical; runs are also recorded in workflow_runs.
# Default (unset) keeps the legacy cron dispatch. Reversible by unsetting.
# WORKFLOW_SCHEDULER=true
