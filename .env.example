# X username to scrape
X_USERNAME=wifsimster

# Session tokens for web scraping — extract from browser cookies after login
# 1. Log in to x.com in your browser
# 2. Open DevTools → Application → Cookies → https://x.com
# 3. Copy the values of "auth_token" and "ct0"
X_SESSION_AUTH_TOKEN=
X_SESSION_CSRF_TOKEN=

# Optional: override GraphQL operation IDs when X changes them
# X_GQL_USER_BY_SCREEN_NAME_ID=qW5u-DAuXpMEG0zA1F7UGQ
# X_GQL_HOME_TIMELINE_ID=ulQKqowrFU94KfUAZqgGvg

# --- AI provider ---------------------------------------------------------------
# Solopilot talks to any OpenAI-compatible endpoint. Pick ONE of the two setups.
#
# Option A (default) — GitHub Models, free. Fine-grained PAT with the
# `models:read` scope (https://github.com/settings/tokens). Also enables GitHub
# repo-context enrichment during content generation.
GITHUB_TOKEN=
#
# Option B — OpenRouter (or any OpenAI-compatible provider). No expiring PAT.
# AI_BASE_URL=https://openrouter.ai/api/v1
# AI_API_KEY=sk-or-...
#
# GITHUB_TOKEN stays optional and, if set alongside Option B, is still used to
# read the product's GitHub repo for context (but not for inference).

# Optional — model id. GitHub Models catalog (https://github.com/marketplace/models)
# or an OpenRouter model (https://openrouter.ai/models), e.g. anthropic/claude-3.5-sonnet
# AI_MODEL=openai/gpt-4.1
# TWEETS_LOOKBACK_DAYS=1
# DRY_RUN=true
# CRON_SCHEDULE=30 7 * * *

# Back-office
# ADMIN_PASSWORD=your-secure-password
# WEB_PORT=3000

# Optional — Discord webhook URL for automatic summary notifications
# Create a webhook in Discord: Server Settings → Integrations → Webhooks
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Optional — Stripe secret key for the Facturation module. When unset, invoicing
# works as a local ledger and Stripe sync is a no-op. https://dashboard.stripe.com/apikeys
# STRIPE_API_KEY=sk_live_...

# Optional — Stripe publishable key. Required only to mount the embedded Checkout
# ("Encaisser" on an invoice); without it the action stays hidden.
# STRIPE_PUBLISHABLE_KEY=pk_live_...

# Optional — calendar ICS feed URL for the Agenda module (e.g. Google Calendar
# "secret address in iCal format"). When unset, Agenda works as a local store.
# AGENDA_ICS_URL=https://calendar.google.com/calendar/ical/.../basic.ics

# Optional — custom SQLite database path (defaults to ./data/bot.db)
# DB_PATH=./data/bot.db

# Optional — route production veille through the workflow engine (the "flip",
# ADR-0020). Behaviour is identical; runs are also recorded in workflow_runs.
# Default (unset) keeps the legacy cron dispatch. Reversible by unsetting.
# WORKFLOW_SCHEDULER=true

# ---------------------------------------------------------------------------
# CLI client (optional) — these configure the `solopilot` CLI (HTTP API client
# for agents), NOT the server. Ignored by the server process; read by the CLI.
# ---------------------------------------------------------------------------
# Base URL the CLI targets (overridable with --url). Default http://localhost:3000
# SOLOPILOT_API_URL=https://your-host
# Admin password for the CLI's HTTP Basic auth (admin:<password>; overridable with
# --password). Falls back to ADMIN_PASSWORD if unset.
# SOLOPILOT_ADMIN_PASSWORD=your-secure-password
